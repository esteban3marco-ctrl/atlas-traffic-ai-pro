##################################
# SPECIAL RULES FOR ATLAS PRO
##################################

# NEVER COMMIT:
# ❌ Trained AI models
# ❌ Dueling DDQN weights
# ❌ QMIX coordinator weights
# ❌ MUSE metacognition models
# ❌ Real traffic data
# ❌ Customer configuration
# ❌ API credentials
# ❌ Deployment scripts with secrets
# ❌ Database backups with customer data

# ALWAYS COMMIT:
# ✅ Documentation (README, DEPLOYMENT_GUIDE, etc.)
# ✅ Public API specs
# ✅ Architecture diagrams (ASCII or plantuml)
# ✅ License files
# ✅ Contributing guidelines
# ✅ Example configurations (sanitized)
# ✅ Deployment scripts (without secrets)

##################################
# EDGE CASES
##################################

# Don't commit compiled documentation
site/
docs/_build/

# Don't commit virtual environments
venv/
env/
ENV/
.venv/

# Don't commit dependency locks (for libraries)
# But DO commit for applications:
# ✅ requirements.txt (commit)
# ✅ package-lock.json (commit for apps)
# ❌ poetry.lock (for libraries, not for apps)

# Don't commit IDE-specific settings
.editorconfig.local
.prettierrc.local

##################################
# GIT-SPECIFIC
##################################

# Git LFS pointer files are OK to commit
# *.pth filter=lfs diff=lfs merge=lfs -text

# Merge conflict artifacts
*.orig
*.rej

##################################
# DEPLOYMENT-SPECIFIC
##################################

# Docker volumes (local development only)
volume/
volumes/

# Kubernetes manifests with secrets (use sealed-secrets)
k8s/secrets/
kustomization/secrets/

# Terraform state files (use remote state!)
*.tfstate
*.tfstate.*
.terraform/
terraform.tfvars

# Ansible inventory with real IPs
inventory/production
inventory/staging

##################################
# SECURITY WARNING
##################################

# If you accidentally commit secrets:
# 1. Immediately revoke them
# 2. Delete from git history: git filter-branch
# 3. Force push: git push --force-with-lease
# 4. Announce rotation to all users

# Use git-secrets to prevent future accidents:
# https://github.com/awslabs/git-secrets

##################################
# FILE SIZE LIMITS
##################################

# GitHub limits: 100 MB per file, 5 GB per repo
# Prevent committing large files:
# ✅ Use Git LFS for > 10 MB
# ✅ Use .gitattributes for LFS setup
# ✅ Never commit model files directly

##################################

# Last Updated: Feb 2026
# Review regularly for new secrets/sensitive data

